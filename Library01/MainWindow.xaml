<Window x:Class="Library01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой книг" Height="600" Width="1000"
        Loaded="Window_Loaded">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Управление библиотекой книг"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- Панель фильтрации -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Поиск по названию:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="TxtSearch" Width="180" Margin="0,0,12,0"
                     TextChanged="TxtSearch_TextChanged"/>

            <TextBlock Text="Автор:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CmbAuthor" Width="150" Margin="0,0,12,0"
                      SelectionChanged="Filter_Changed"/>

            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="CmbGenre" Width="150" Margin="0,0,12,0"
                      SelectionChanged="Filter_Changed"/>

            <Button Content="Сбросить фильтры" Padding="8,2" Click="BtnResetFilter_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="DgBooks"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Авторы" Binding="{Binding AuthorsDisplay}" Width="180"/>
                <DataGridTextColumn Header="Жанры" Binding="{Binding GenresDisplay}" Width="150"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="60"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="130"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Добавить книгу" Padding="8,4" Margin="0,0,8,0" Click="BtnAddBook_Click"/>
            <Button Content="Редактировать" Padding="8,4" Margin="0,0,8,0" Click="BtnEditBook_Click"/>
            <Button Content="Удалить" Padding="8,4" Margin="0,0,24,0" Click="BtnDeleteBook_Click"/>
            <Button Content="Управление авторами" Padding="8,4" Margin="0,0,8,0" Click="BtnAuthors_Click"/>
            <Button Content="Управление жанрами" Padding="8,4" Click="BtnGenres_Click"/>
        </StackPanel>
    </Grid>
</Window>
