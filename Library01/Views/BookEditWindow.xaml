<Window x:Class="Library01.Views.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="480" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTitle" Margin="0,4"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Год издания:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtYear" Margin="0,4"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="ISBN:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtISBN" Margin="0,4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Кол-во:" VerticalAlignment="Center" Margin="0,4"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtQty" Margin="0,4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Авторы:" VerticalAlignment="Top" Margin="0,4"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,4">
            <ListBox x:Name="LbAuthors" Height="90" SelectionMode="Multiple"
                     DisplayMemberPath="DisplayName"/>
        </StackPanel>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Жанры:" VerticalAlignment="Top" Margin="0,4"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,4">
            <ListBox x:Name="LbGenres" Height="90" SelectionMode="Multiple"
                     DisplayMemberPath="Name"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Сохранить" Padding="12,4" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Padding="12,4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
